PORT=3001
NODE_ENV=development

# String de conexão do MongoDB (local, Atlas free tier, ou plugin do Railway)
MONGODB_URI=mongodb://localhost:27017/authgps

# Coordenadas do centro da zona permitida (escola, empresa, etc.)
# Para obter suas coordenadas: maps.google.com -> clique com botão direito -> "O que há aqui?"
ALLOWED_LAT=-27.03171092
ALLOWED_LNG=-50.91163717
ALLOWED_RADIUS_METERS=50

# IPs permitidos (separados por vírgula)
# 127.0.0.1, ::1 e ::ffff:127.0.0.1 são localhost (dev)
# Adicione o IP da rede da empresa/escola para produção
ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1,localhost

# Modo de autenticação:
#   BOTH   = IP E GPS devem passar (mais seguro)
#   GPS    = apenas GPS
#   IP     = apenas IP
#   EITHER = IP OU GPS (pelo menos um)
AUTH_MODE=BOTH

# Segredo para assinar os tokens JWT — mude em produção!
JWT_SECRET=mude-este-segredo-em-producao

# Habilita o header X-Simulated-IP pra testar localmente sem precisar de VPN.
# NUNCA habilitar em produção (e nunca habilita se NODE_ENV=production, mesmo que true).
ALLOW_IP_SIMULATION=false

# Quantos hops de proxy reverso confiável existem na frente do backend.
# Railway/Render = 1. Usado pelo Express pra ler X-Forwarded-For com segurança.
TRUST_PROXY_HOPS=1

# Origem(ns) permitida(s) pro CORS em produção (separadas por vírgula).
# Ex: https://meu-frontend.up.railway.app
CORS_ORIGIN=*
